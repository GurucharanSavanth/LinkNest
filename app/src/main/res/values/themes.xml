<resources>
    <style name="Theme.LinkNest.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/linknest_window_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_linknest_mark</item>
        <item name="postSplashScreenTheme">@style/Theme.LinkNest</item>
    </style>

    <style name="Theme.LinkNest" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/linknest_window_background</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>
